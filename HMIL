<!DOCTYPE html>
<html>
<head>
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>EV Charging PM Dashboard</title>

<style>
body{
    font-family: Arial, sans-serif;
    margin:0;
    padding:10px;
    background:#f4f6f9;
}

h1{
    text-align:center;
    font-size:22px;
}

.dashboard-cards{
    display:grid;
    grid-template-columns: repeat(auto-fit, minmax(150px,1fr));
    gap:10px;
    margin:15px 0;
}

.card{
    background:white;
    padding:15px;
    border-radius:10px;
    text-align:center;
    box-shadow:0 2px 6px rgba(0,0,0,0.1);
}

.card h2{
    margin:5px 0;
    font-size:20px;
}

.table-container{
    overflow-x:auto;
}

table{
    width:100%;
    border-collapse:collapse;
    background:white;
    min-width:600px;
}

th,td{
    padding:8px;
    text-align:center;
    border-bottom:1px solid #ddd;
    font-size:14px;
}

th{
    background:#007bff;
    color:white;
}

.overdue{
    background:#ff4d4d;
    color:white;
}

.duesoon{
    background:#ffc107;
}

.ok{
    background:#28a745;
    color:white;
}

/* Mobile adjustments */
@media(max-width:600px){
    h1{
        font-size:18px;
    }
    th,td{
        font-size:12px;
        padding:6px;
    }
}
</style>
</head>

<body>

<h1>EV Charging Station - PM Dashboard</h1>

<div class="dashboard-cards">
    <div class="card">
        <h2 id="totalStations">0</h2>
        <p>Total Chargers</p>
    </div>
    <div class="card">
        <h2 id="overdueCount">0</h2>
        <p>Overdue</p>
    </div>
    <div class="card">
        <h2 id="dueSoonCount">0</h2>
        <p>Due Soon</p>
    </div>
    <div class="card">
        <h2 id="okCount">0</h2>
        <p>OK</p>
    </div>
</div>

<div class="table-container">
<table>
<thead>
<tr>
<th>Station</th>
<th>Charger ID</th>
<th>Last PM</th>
<th>Frequency</th>
<th>Next PM</th>
<th>Status</th>
</tr>
</thead>
<tbody id="pmTable"></tbody>
</table>
</div>

<script>

const data = [
{station:"Vadodara-01", charger:"240kW-01", lastPM:"2026-02-01", frequency:30},
{station:"Vadodara-02", charger:"240kW-02", lastPM:"2026-01-10", frequency:30},
{station:"Surat-01", charger:"AC-01", lastPM:"2026-02-15", frequency:15},
{station:"Ahmedabad-01", charger:"AC-02", lastPM:"2026-01-25", frequency:20}
];

const today = new Date();
let overdue=0, dueSoon=0, ok=0;

function calculateNextPM(lastPM, frequency){
let date = new Date(lastPM);
date.setDate(date.getDate() + frequency);
return date;
}

function getStatus(nextPM){
let diff = (nextPM - today)/(1000*60*60*24);
if(diff < 0){
overdue++;
return "OVERDUE";
}
else if(diff <= 3){
dueSoon++;
return "DUE SOON";
}
else{
ok++;
return "OK";
}
}

const table = document.getElementById("pmTable");

data.forEach(item=>{
let nextPM = calculateNextPM(item.lastPM, item.frequency);
let status = getStatus(nextPM);

let row = `<tr class="${status === 'OVERDUE' ? 'overdue' : status === 'DUE SOON' ? 'duesoon' : 'ok'}">
<td>${item.station}</td>
<td>${item.charger}</td>
<td>${item.lastPM}</td>
<td>${item.frequency}</td>
<td>${nextPM.toISOString().split('T')[0]}</td>
<td>${status}</td>
</tr>`;

table.innerHTML += row;
});

document.getElementById("totalStations").innerText = data.length;
document.getElementById("overdueCount").innerText = overdue;
document.getElementById("dueSoonCount").innerText = dueSoon;
document.getElementById("okCount").innerText = ok;

</script>

</body>
</html>
